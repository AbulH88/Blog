{"nodes": [{"id": "srs_frs_cristina_platform", "label": "SRS & FRS \u2014 Cristina Platform", "file_type": "document", "source_file": "SRS_FRS_DOCUMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "freemium_ppv_model", "label": "Freemium + PPV Business Model", "file_type": "rationale", "source_file": "SRS_FRS_DOCUMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Free signup with revenue from per-bundle unlocks, per-post unlocks, PPV chat messages, and Fanvue redirect. Subscription model repurposed as free follower record. Chosen over subscription-first to reduce friction and bypass payment processor restrictions on adult platforms."}, {"id": "v3_design_system", "label": "V3 Design System (terracotta/navy/cream palette)", "file_type": "rationale", "source_file": "SRS_FRS_DOCUMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unified palette: terracotta + navy + cream (desktop), soft rose (mobile). Serif italic display font (Cormorant Garamond). Replaces old dark surfaces. Rationale: mobile-first influencer aesthetic with high trust score for Instagram traffic."}, {"id": "sequelize_sqlite_postgres", "label": "Sequelize ORM (SQLite dev \u2192 PostgreSQL prod)", "file_type": "rationale", "source_file": "SRS_FRS_DOCUMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SQLite for zero-config dev. Postgres for production reliability and query performance. applyMigrations helper uses addIfMissing/addColumn for non-destructive schema evolution without full Sequelize migrations."}, {"id": "socketio_realtime", "label": "Socket.io Realtime Chat", "file_type": "rationale", "source_file": "SRS_FRS_DOCUMENT.md", "source_location": null, "source_url": null, "captured_at": null, "author": n