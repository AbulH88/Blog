:null},{"id":"react_svg","label":"React Logo SVG (React cyan atom icon)","file_type":"image","source_file":"client/src/assets/react.svg","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"vite_svg","label":"Vite Logo SVG (Vite purple lightning bolt)","file_type":"image","source_file":"client/src/assets/vite.svg","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"freemium_ppv_model","label":"Freemium + PPV Business Model","file_type":"rationale","source_file":"SRS_FRS_DOCUMENT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Free signup with revenue from per-bundle unlocks, per-post unlocks, PPV chat messages, and Fanvue redirect. Subscription model repurposed as free follower record. Chosen over subscription-first to reduce friction and bypass payment processor restrictions on adult platforms."},{"id":"v3_design_system","label":"V3 Design System (terracotta/navy/cream palette)","file_type":"rationale","source_file":"SRS_FRS_DOCUMENT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Unified palette: terracotta + navy + cream (desktop), soft rose (mobile). Serif italic display font (Cormorant Garamond). Replaces old dark surfaces. Rationale: mobile-first influencer aesthetic with high trust score for Instagram traffic."},{"id":"instagram_bridge_strategy","label":"Instagram Bridge Strategy (Blog as Trust Layer)","file_type":"rationale","source_file":"FUNNEL_MARKETING_PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Blog acts as a trust bridge between Instagram (top of funnel) and Fanvue (monetization). Instagram bots crawl the blog and see a legitimate lifestyle site, giving a high trust score. Also provides data capture via email/push notifications."},{"id":"safe_word_replacement","label":"Safe Word Replacement Policy","file_type":"rationale","source_file":"creator_blog_funnel_requirements.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Replace trigger words (OnlyFans→Exclusive, 18+→Private, NSFW→VIP, Adult→Premium) to avoid Instagram/domain blacklisting and maintain a high brand trust score."},{"id":"instagram_funnel_flow","label":"Instagram→Blog→VIP→Fanvue Funnel Flow","file_type":"rationale","source_file":"creator_blog_funnel_requirements.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Traffic enters via Instagram, bridges through the blog/website for trust-building, then converts via VIP/exclusive content CTA redirecting to Fanvue monetization."},{"id":"phase6_payments","label":"Phase 6 — Real Payments (Multi-provider Abstraction)","file_type":"rationale","source_file":"README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Provider-agnostic PaymentProvider interface with pluggable backends (mock, NOWPayments crypto, Stripe, PayPal). Crypto-first (NOWPayments) chosen for pre-launch due to no KYC requirement."},{"id":"phase7_instagram_oauth","label":"Phase 7 — Instagram Basic Display API (Option A)","file_type":"rationale","source_file":"README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Instagram disabled public iframe embeds Q4 2024. Real IG feed requires OAuth via Meta Basic Display API. Interim fallback uses creator gallery images + Follow CTA."},{"id":"phase8_production_hardening","label":"Phase 8 — Production Hardening","file_type":"rationale","source_file":"README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"AWS S3 for media (current /uploads/ paths are scrapable), PostgreSQL over SQLite, helmet/rate-limiting security headers, email verification, custom domains per creator."},{"id":"cloudflare_cdn_waf","label":"Cloudflare CDN + WAF Strategy","file_type":"rationale","source_file":"server/scripts/CLOUDFLARE.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Saves ~95% bandwidth by caching /uploads/. WAF rules block bad bots, empty User-Agent scrapers, and geo-block US adult-verification-law states (TX, LA, UT, etc.) to avoid compliance liability."},{"id":"aapanel_pm2_nginx","label":"aaPanel + PM2 Cluster + nginx Deployment Stack","file_type":"rationale","source_file":"server/scripts/DEPLOY.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"PM2 cluster mode with 2 workers load-balances across VPS cores. nginx serves static Vite build directly, proxies /api/ and /socket.io/ to Node. Restricts origin access to Cloudflare IPs only to prevent WAF bypass."},{"id":"react_vite_ts_stack","label":"React 19 + Vite + TypeScript Frontend Stack","file_type":"rationale","source_file":"README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"React 19 with Vite for HMR and fast builds. TypeScript for type safety. React Router 7 for SPA routing. Chosen over Next.js for simpler single-tenant deployment."},{"id":"sequelize_sqlite_postgres","label":"Sequelize ORM (SQLite dev → PostgreSQL prod)","file_type":"rationale","source_file":"SRS_FRS_DOCUMENT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"SQLite for zero-config dev. Postgres for production reliability and query performance. applyMigrations helper uses addIfMissing/addColumn for non-destructive schema evolution without full Sequelize migrations."},{"id":"socketio_realtime","label":"Socket.io Realtime Chat","file_type":"rationale","source_file":"SRS_FRS_DOCUMENT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Socket.io rooms per user (fan:userId, creator:creatorId) with JWT auth handshake. Supports PPV media unlock events and typing indicators in real time."},{"id":"instagram_option_a_pdf","label":"Instagram Option A Setup (PDF guide)","file_type":"document","source_file":"docs/instagram-option-a-setup.pdf","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null}],"edges":[{"source":"readme_cristina_platform","target":"srs_frs_cristina_platform","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"README.md","source_location":"Other docs table","weight":1.0},{"source":"readme_cristina_platform","target":"technical_guide_v1","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"README.md","source_location":"Other docs table","weight":1.0},{"source":"readme_cristina_platform","target":"funnel_requirements_v1","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"README.md","source_location":"Other docs table","weight":1.0},{"source":"readme_cristina_platform","target":"instagram_option_a_pdf","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"README.md","source_location":"Phase 7 section","weight":1.0},{"source":"srs_frs_cristina_platform","target":"instagram_option_a_pdf","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"SRS_FRS_DOCUMENT.md","source_location":"Phase 7 section","weight":1.0},{"source":"srs_frs_cristina_platform","target":"funnel_marketing_plan","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"SRS_FRS_DOCUMENT.md","source_location":"File map","weight":1.0},{"source":"srs_frs_cristina_platform","target":"freemium_ppv_model","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"SRS_FRS_DOCUMENT.md","source_location":"Business mo