# ── Required ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace_with_64_random_hex_chars
JWT_EXPIRES_IN=24h

# Server port (3000-5000 typical, 80/443 in production behind a reverse proxy)
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
# Dev default: SQLite (no setup). Production: Postgres via aaPanel.
#
# SQLite (dev):
DB_DIALECT=sqlite
DATABASE_PATH=./data/platform.db
#
# Postgres (production):
# DB_DIALECT=postgres
# DATABASE_URL=postgres://cristina_app:PASSWORD@localhost:5432/cristina_prod
#   — OR — split form:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cristina_prod
# DB_USER=cristina_app
# DB_PASSWORD=...
# DB_SSL=false   # set to true only if Postgres is remote (Supabase, Neon, RDS)

# ── Redis ────────────────────────────────────────────────────────────────────
# Required in production for PM2 cluster mode, Socket.IO across workers,
# and persistent rate-limit state. Dev runs fine without it (graceful no-op).
#
# Single URL (preferred):
# REDIS_URL=redis://localhost:6379
#
# OR split form:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=...

# Platform fee % cut from each transaction (informational, used in admin analytics)
PLATFORM_FEE_PERCENT=10

# Public-facing site URL — used in email links, AI prompt context, OAuth callbacks
SITE_URL=https://thecristinaadam.com

# CORS allow-list (comma-separated, no trailing slashes). Browsers calling
# /api/* from any origin not in this list will be blocked. Include both apex
# and www. variants if you serve both. Dev fallback is localhost when unset.
# IMPORTANT: include both the marketing root AND the members.* subdomain.
ALLOWED_ORIGINS=https://thecristinaadam.com,https://www.thecristinaadam.com,https://members.thecristinaadam.com

# Where fans land after authenticated flows (email verification links,
# password reset, NOWPayments hosted-checkout redirects). Point this at the
# MEMBERS subdomain — that's where Register/Login/Dashboard live after the
# domain split. The marketing root domain only carries linktree + legal pages.
PUBLIC_APP_URL=https://members.thecristinaadam.com

# Where NOWPayments POSTs IPN webhooks. MUST be publicly reachable.
#  - Local testing: use ngrok (`ngrok http 5000`) and paste the https URL.
#  - Production: your real API host (typically the same as PUBLIC_APP_URL).
# Leave empty for crypto-only without webhooks (status polling fallback works).
PUBLIC_API_URL=https://thecristinaadam.com

# ── AI Chatbot (OpenRouter) ─────────────────────────────────────────────────
# Sign up at https://openrouter.ai → API keys → create new key.
# Sets a $50/mo spending cap recommended.
OPENROUTER_API_KEY=sk-or-v1-...
# Override the cheap intent-classifier model (default is anthropic/claude-haiku-4.5)
# AI_CLASSIFIER_MODEL=anthropic/claude-haiku-4.5

# ── NOWPayments (crypto checkout) ───────────────────────────────────────────
# Sign up at https://nowpayments.io → Settings → API → create key + IPN secret.
# IMPORTANT: set the IPN secret here AND in NOWPayments dashboard → IPN Settings.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Override the API base (default https://api.nowpayments.io/v1) — only needed for sandbox
# NOWPAYMENTS_PUBLIC_URL=https://api.nowpayments.io/v1

# ── Card processor (Verotel, Segpay, etc.) ───────────────────────────────────
# Set CARD_PROVIDER to enable card processing. Defaults to 'mock' in dev.
# CARD_PROVIDER=verotel
# CARD_PROVIDER_API_KEY=
# CARD_PROVIDER_WEBHOOK_SECRET=

# ── Future (Phase 8 production hardening) ───────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...
# AWS_REGION=us-east-1
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
